# =============================================================================
# Backstage Dev Portal — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# .env is git-ignored and should NEVER be committed.
# =============================================================================

# --- GitHub Integration ---
# Personal Access Token for GitHub API access (repo read, webhook, etc.)
GITHUB_TOKEN=
# GitHub organization name for org-based catalog ingestion
GITHUB_ORG=

# --- GitHub OAuth (Auth Provider) ---
# OAuth App credentials from GitHub Developer Settings
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# --- Microsoft / Azure AD OAuth (Auth Provider, production) ---
# App Registration credentials from Azure Portal
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=

# --- PostgreSQL ---
# Database connection used by docker-compose and production configs
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Application ---
# Base URL where Backstage is served (e.g., http://localhost:7007 or https://portal.example.com)
APP_BASE_URL=

# --- Platform Templates ---
# URL to the Location YAML that registers all scaffolder templates
# Example: https://github.com/your-org/platform-templates/blob/main/all-templates.yaml
PLATFORM_TEMPLATES_URL=
